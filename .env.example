# Server-only provider credentials. Never expose these with a NEXT_PUBLIC_ prefix.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Higgsfield officially connects through account-authenticated MCP, not an API key.
# The OAuth/MCP session will be added after the Higgsfield account is authorized.
HIGGSFIELD_MCP_CONNECTED=false

# Provider-cost guard for the owner account. Grow defaults to USD 24/month.
TERRACOTTA_MONTHLY_BUDGET_USD=24
