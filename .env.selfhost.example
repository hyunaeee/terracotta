# Copy this file to .env, then add only the providers you want Terracotta to use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Higgsfield connects through its authenticated MCP flow.
HIGGSFIELD_MCP_CONNECTED=false

# Monthly provider API-cost guard in USD.
TERRACOTTA_MONTHLY_BUDGET_USD=24

# Optional. Leave blank to generate and persist a private 32-byte key on first boot.
MCP_TOKEN_ENCRYPTION_KEY=

# Safe default: only this computer can reach Terracotta.
TERRACOTTA_BIND=127.0.0.1
TERRACOTTA_PORT=3000

# Pin a published container tag such as v0.2.0 when desired.
TERRACOTTA_VERSION=latest
